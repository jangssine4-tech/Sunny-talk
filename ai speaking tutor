function goToLessons() {
  document.getElementById('lessons-student-name').textContent = state.currentStudent.name + ' ✨';
  document.getElementById('streak-count').textContent = state.streak + '🔥';
  renderLessons();
  goTo('screen-lessons');
}

function renderLessons() {
  const completed = LS.getCompleted(state.currentStudent.id);
  const todayIdx = completed.length % LESSONS.length;
  document.getElementById('lesson-grid').innerHTML = LESSONS.map((l, i) => {
    const isDone = completed.includes(l.id);
    const isToday = i === todayIdx;
    const lvlCls = l.level === 'beginner' ? 'level-beginner' : l.level === 'intermediate' ? 'level-intermediate' : 'level-advanced';
    const lvlTxt = l.level === 'beginner' ? '초급' : l.level === 'intermediate' ? '중급' : '고급';
    return `<div class="lesson-card ${isToday ? 'today' : ''} ${isDone ? 'completed' : ''}" onclick="startLesson('${l.id}')">
      <span class="lesson-icon">${l.icon}</span>
      <div class="lesson-title">${l.title}</div>
      <div class="lesson-sub">${l.titleKo}</div>
      <div class="lesson-level ${lvlCls}">${lvlTxt}</div>
    </div>`;
  }).join('');
}

// ──────────────────────────────────────
// Start Lesson
// ──────────────────────────────────────
function startLesson(lessonId) {
  state.currentLesson = LESSONS.find(l => l.id === lessonId);
  if (!state.currentLesson) return;

  // Setup UI
  document.getElementById('convo-lesson-title').textContent =
    state.currentLesson.icon + ' ' + state.currentLesson.title;

  document.getElementById('vocab-strip').innerHTML =
    state.currentLesson.vocab.map(v =>
      `<div class="vocab-pill" onclick="vocabTap('${v.en}')">${v.en} · ${v.ko}</div>`
    ).join('');

  // Reset chat
  const area = document.getElementById('chat-area');
  area.querySelectorAll('.chat-bubble').forEach(b => b.remove());
  document.getElementById('sunny-center').style.display = 'flex';

  // Timer
  const settings = LS.getSettings();
  state.sessionDuration = parseInt(settings.sessionLength || 600);
  state.sessionSeconds = state.sessionDuration;
  state.sessionTurns = 0;
  state.sessionStartTime = Date.now();
  clearInterval(state.timerInterval);
  updateTimer();
  state.timerInterval = setInterval(() => {
    state.sessionSeconds--;
    updateTimer();
    if (state.sessionSeconds <= 0) endSession();
  }, 1000);

  // Mic disabled until connected
  document.getElementById('mic-btn').disabled = true;
  setSessionStatus('connecting');

  goTo('screen-convo');
  setTimeout(connectRealtime, 600);
}

function updateTimer() {
  const m = Math.floor(state.sessionSeconds / 60);
  const s = state.sessionSeconds % 60;
  document.getElementById('timer-display').textContent = m + ':' + String(s).padStart(2, '0');
  const pct = (state.sessionSeconds / state.sessionDuration) * 100;
  const bar = document.getElementById('timer-bar');
  bar.style.width = pct + '%';
  bar.style.background = pct > 50 ? 'var(--yellow)' : pct > 25 ? '#FF9B30' : 'var(--coral)';
}

function setSessionStatus(status, text) {
  const el = document.getElementById('session-status');
  const labels = {
    connecting: ['status-connecting', '⏳ 연결 중'],
    connected:  ['status-connected',  '🟢 연결됨'],
    error:      ['status-error',      '❌ 오류'],
    demo:       ['status-demo',       '🔵 데모'],
  };
  const [cls, lbl] = labels[status] || labels.demo;
  el.className = 'status-badge ' + cls;
  el.textContent = text || lbl;
}

// ──────────────────────────────────────
// ✅ WebRTC — Functions 프록시 사용
//    API Key는 클라이언트에 없음
// ──────────────────────────────────────
async function connectRealtime() {
  const settings = LS.getSettings();
  const functionsUrl = settings.functionsUrl;
  const appSecret = settings.appSecret;

  // Functions URL이 없으면 데모 모드
  if (!functionsUrl) {
    toast('Functions URL 미설정 → 데모 모드로 실행');
    startDemoMode();
    return;
  }

  const model = settings.model || 'gpt-4o-mini-realtime-preview-2024-12-17';

  try {
    document.getElementById('mic-label').textContent = '🔐 서버에서 세션 토큰 발급 중...';

    // ✅ Step 1: Functions에 ephemeral token 요청
    //    API Key는 Functions 서버에만 있음 — 클라이언트에는 절대 오지 않음
    const tokenRes = await fetch(functionsUrl, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        // Functions에 앱 식별자 전달 (API Key 아님)
        'x-app-secret': appSecret || '',
      },
      body: JSON.stringify({
        model,
        instructions: state.currentLesson.systemPrompt,
        voice: 'shimmer',
      }),
    });

    if (!tokenRes.ok) {
      const err = await tokenRes.json().catch(() => ({}));
      throw new Error('Functions 오류: ' + (err.error || tokenRes.status));
    }

    const { token } = await tokenRes.json();
    if (!token) throw new Error('토큰이 없습니다');

    document.getElementById('mic-label').textContent = '🔗 음성 연결 중...';

    // ✅ Step 2: 받은 ephemeral token으로 WebRTC 연결
    //    이 token은 60초 수명, 1회용 → 노출돼도 즉시 만료
    state.peerConnection = new RTCPeerConnection();
    state.audioEl = document.createElement('audio');
    state.audioEl.autoplay = true;

    state.peerConnection.ontrack = (e) => {
      state.audioEl.srcObject = e.streams[0];
    };

    // 마이크 스트림 추가
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    stream.getTracks().forEach(track => state.peerConnection.addTrack(track, stream));

    // 데이터 채널
    state.dataChannel = state.peerConnection.createDataChannel('oai-events');
    state.dataChannel.onmessage = handleRealtimeEvent;
    state.dataChannel.onopen = () => {
      state.connected = true;
      document.getElementById('mic-btn').disabled = false;
      document.getElementById('mic-label').textContent = '마이크 버튼을 눌러 말해보세요!';
      setSessionStatus('connected');
      // 첫 인사 트리거
      setTimeout(() => sendEvent({ type: 'response.create', response: { modalities: ['audio', 'text'] } }), 800);
    };

    state.dataChannel.onclose = () => {
      state.connected = false;
      setSessionStatus('error', '🔴 연결 끊김');
    };

    // ✅ SDP 교환 — ephemeral token 사용 (API Key 아님)
    const offer = await state.peerConnection.createOffer();
    await state.peerConnection.setLocalDescription(offer);

    const sdpRes = await fetch(
      'https://api.openai.com/v1/realtime?model=' + model,
      {
        method: 'POST',
        headers: {
          'Authorization': 'Bearer ' + token, // 60초짜리 1회용 token
          'Content-Type': 'application/sdp',
        },
        body: offer.sdp,
      }
    );

    if (!sdpRes.ok) throw new Error('WebRTC SDP 교환 실패: ' + sdpRes.status);

    const answerSdp = await sdpRes.text();
    await state.peerConnection.setRemoteDescription({ type: 'answer', sdp: answerSdp });

  } catch (err) {
    console.error('[connectRealtime]', err);
    toast('연결 실패: ' + err.message + ' → 데모 모드 전환');
    setSessionStatus('error', '❌ ' + err.message.slice(0, 20));
    startDemoMode();
  }
}

function sendEvent(obj) {
  if (state.dataChannel?.readyState === 'open') {
    state.dataChannel.send(JSON.stringify(obj));
  }
}

// ──────────────────────────────────────
// Realtime 이벤트 처리
// ──────────────────────────────────────
function handleRealtimeEvent(event) {
  let data; try { data = JSON.parse(event.data); } catch { return; }
  switch (data.type) {
    case 'response.audio_transcript.delta':
      updateLastAiBubble(data.delta || '');
      setSunnyTalking(true);
      break;
    case 'response.audio_transcript.done':
      setSunnyTalking(false);
      finalizeAiBubble(data.transcript || '');
      state.sessionTurns++;
      break;
    case 'input_audio_buffer.speech_started':
      setListening(true);
      break;
    case 'input_audio_buffer.speech_stopped':
      setListening(false);
      break;
    case 'conversation.item.input_audio_transcription.completed':
      addUserBubble(data.transcript || '...');
      state.sessionTurns++;
      break;
    case 'error':
      toast('오류: ' + (data.error?.message || '알 수 없는 오류'));
      break;
  }
}

