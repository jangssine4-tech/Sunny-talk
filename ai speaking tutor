<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Sunny Talk — AI 영어 튜터</title>
<link rel="manifest" href="/manifest.json">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --cream:#FFFBEF; --purple:#2D1B69; --purple-light:#4A3296;
  --purple-pale:#EDE9FF; --yellow:#FFD23F; --yellow-dark:#E8B800;
  --coral:#FF6B6B; --coral-light:#FFE5E5; --sky:#4FC3F7;
  --sky-light:#E1F5FE; --green:#69D98C; --green-light:#E8FFF0;
  --text:#1A1035; --text-muted:#6B5FA0; --white:#FFFFFF;
  --shadow:0 8px 32px rgba(45,27,105,.15);
  --shadow-sm:0 4px 16px rgba(45,27,105,.10);
  --radius:24px; --radius-sm:16px; --radius-xs:10px;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{width:100%;height:100%;overflow:hidden;font-family:'Nunito',sans-serif;background:var(--cream);color:var(--text)}

/* ── Screens ── */
.screen{position:fixed;inset:0;display:flex;flex-direction:column;align-items:center;overflow-y:auto;overflow-x:hidden;opacity:0;pointer-events:none;transform:translateY(24px);transition:opacity .35s ease,transform .35s cubic-bezier(.34,1.2,.64,1)}
.screen.active{opacity:1;pointer-events:all;transform:none}
.screen.exit{opacity:0;transform:translateY(-24px);transition:opacity .25s ease,transform .25s ease}

/* ── Blobs ── */
.bg-blobs{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.blob{position:absolute;border-radius:50%;filter:blur(60px);opacity:.18}
.blob-1{width:400px;height:400px;background:var(--yellow);top:-100px;right:-100px;animation:blobFloat 8s ease-in-out infinite}
.blob-2{width:300px;height:300px;background:var(--sky);bottom:-80px;left:-80px;animation:blobFloat 10s ease-in-out infinite reverse}
.blob-3{width:200px;height:200px;background:var(--coral);top:40%;left:60%;animation:blobFloat 12s ease-in-out infinite 2s}
@keyframes blobFloat{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(20px,-20px) scale(1.05)}66%{transform:translate(-15px,10px) scale(.97)}}

/* ── Character ── */
.sunny-body{animation:sunnyBob 3s ease-in-out infinite;transform-origin:center bottom}
@keyframes sunnyBob{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.eye-upper{animation:eyeBlink 4s ease-in-out infinite;transform-origin:center bottom}
@keyframes eyeBlink{0%,90%,100%{transform:scaleY(1)}95%{transform:scaleY(0.1)}}
.mouth-path{transition:d .08s ease}
.sunny-svg.talking .mouth-path{animation:mouthTalk .2s ease-in-out infinite alternate}
@keyframes mouthTalk{from{d:path("M 52 78 Q 64 88 76 78")}to{d:path("M 52 76 Q 64 94 76 76")}}
.sunny-svg.thinking .sunny-body{animation:sunnyThink 1.5s ease-in-out infinite}
@keyframes sunnyThink{0%,100%{transform:rotate(-3deg)}50%{transform:rotate(3deg)}}
.star-orbit{animation:starOrbit 6s linear infinite;transform-origin:center center}
.star-orbit-rev{animation:starOrbit 8s linear infinite reverse;transform-origin:center center}
@keyframes starOrbit{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

/* ── Buttons ── */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:14px 28px;border:none;border-radius:100px;font-family:'Nunito',sans-serif;font-size:16px;font-weight:800;cursor:pointer;transition:transform .15s ease,box-shadow .15s ease,background .15s ease;text-decoration:none}
.btn:active{transform:scale(.96)!important}
.btn-primary{background:var(--purple);color:#fff;box-shadow:0 6px 20px rgba(45,27,105,.4)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 28px rgba(45,27,105,.45)}
.btn-yellow{background:var(--yellow);color:var(--purple);box-shadow:0 6px 20px rgba(255,210,63,.5)}
.btn-yellow:hover{transform:translateY(-2px)}
.btn-coral{background:var(--coral);color:#fff;box-shadow:0 6px 20px rgba(255,107,107,.4)}
.btn-ghost{background:var(--purple-pale);color:var(--purple);box-shadow:none}
.btn-ghost:hover{background:#D8D0FF}

/* ── Cards ── */
.card{background:var(--white);border-radius:var(--radius);box-shadow:var(--shadow);padding:24px}
.card-sm{border-radius:var(--radius-sm);padding:16px}

/* ── PIN ── */
.pin-dots{display:flex;gap:16px;margin:24px 0}
.pin-dot{width:20px;height:20px;border-radius:50%;border:3px solid var(--purple-pale);background:transparent;transition:background .2s ease,border-color .2s ease,transform .15s ease}
.pin-dot.filled{background:var(--purple);border-color:var(--purple);transform:scale(1.15)}
.numpad{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;width:100%;max-width:300px}
.numpad-btn{aspect-ratio:1;border:none;border-radius:var(--radius-sm);background:var(--white);color:var(--text);font-family:'Fredoka One',cursive;font-size:28px;box-shadow:0 4px 12px rgba(45,27,105,.1);cursor:pointer;transition:all .12s ease;display:flex;align-items:center;justify-content:center}
.numpad-btn:active{transform:scale(.92);background:var(--purple-pale)}
.numpad-btn.del{font-size:20px;color:var(--text-muted)}

/* ── Lesson cards ── */
.lesson-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;width:100%;padding:0 16px 16px}
.lesson-card{background:var(--white);border-radius:var(--radius-sm);padding:18px 16px;cursor:pointer;box-shadow:var(--shadow-sm);transition:transform .2s ease,box-shadow .2s ease;border:2.5px solid transparent;position:relative;overflow:hidden}
.lesson-card:active{transform:scale(.96)}
.lesson-card.today{border-color:var(--yellow)}
.lesson-card.today::before{content:"TODAY";position:absolute;top:10px;right:-24px;background:var(--yellow);color:var(--purple);font-size:9px;font-weight:900;padding:3px 28px;transform:rotate(45deg);letter-spacing:.5px}
.lesson-card.completed{opacity:.65}
.lesson-card.completed::after{content:"✓";position:absolute;bottom:10px;right:14px;color:var(--green);font-size:20px;font-weight:900}
.lesson-icon{font-size:36px;margin-bottom:8px;display:block}
.lesson-title{font-weight:800;font-size:14px;margin-bottom:4px;color:var(--text)}
.lesson-sub{font-size:11px;color:var(--text-muted);font-weight:600}
.lesson-level{display:inline-block;margin-top:8px;padding:2px 8px;border-radius:100px;font-size:10px;font-weight:800}
.level-beginner{background:var(--green-light);color:#1B7A40}
.level-intermediate{background:var(--sky-light);color:#0D6E9A}
.level-advanced{background:var(--coral-light);color:#A83232}

/* ── Chat ── */
.convo-header{width:100%;display:flex;align-items:center;gap:12px;padding:16px 20px;background:var(--white);box-shadow:0 2px 12px rgba(45,27,105,.08);position:sticky;top:0;z-index:10}
.lesson-badge{flex:1;font-weight:800;font-size:14px;color:var(--purple)}
.chat-area{flex:1;width:100%;overflow-y:auto;padding:16px 16px 24px;display:flex;flex-direction:column;gap:12px}
.chat-bubble{max-width:78%;padding:12px 16px;border-radius:20px;font-size:15px;line-height:1.5;font-weight:600;animation:bubbleIn .25s cubic-bezier(.34,1.2,.64,1)}
@keyframes bubbleIn{from{opacity:0;transform:scale(.9) translateY(6px)}to{opacity:1;transform:none}}
.bubble-ai{background:var(--purple);color:#fff;border-bottom-left-radius:6px;align-self:flex-start}
.bubble-user{background:var(--yellow);color:var(--text);border-bottom-right-radius:6px;align-self:flex-end}
.bubble-hint{background:var(--sky-light);color:#0D6E9A;border-bottom-left-radius:6px;align-self:flex-start;font-size:13px;font-style:italic}
.typing-dots{display:flex;gap:5px;padding:4px 0}
.typing-dots span{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.7);animation:dotBounce .8s ease-in-out infinite}
.typing-dots span:nth-child(2){animation-delay:.15s}
.typing-dots span:nth-child(3){animation-delay:.3s}
@keyframes dotBounce{0%,80%,100%{transform:translateY(0)}40%{transform:translateY(-8px)}}
.mic-area{width:100%;display:flex;flex-direction:column;align-items:center;gap:12px;padding:16px 20px 32px;background:var(--white);box-shadow:0 -2px 16px rgba(45,27,105,.08)}
.mic-btn{width:80px;height:80px;border-radius:50%;border:none;background:var(--purple);color:#fff;font-size:30px;cursor:pointer;position:relative;box-shadow:0 8px 28px rgba(45,27,105,.4);transition:all .15s ease;display:flex;align-items:center;justify-content:center}
.mic-btn.listening{background:var(--coral);box-shadow:0 8px 28px rgba(255,107,107,.5);animation:micPulse 1.2s ease-in-out infinite}
.mic-btn:disabled{opacity:.45;cursor:not-allowed;animation:none}
@keyframes micPulse{0%,100%{transform:scale(1);box-shadow:0 8px 28px rgba(255,107,107,.5)}50%{transform:scale(1.08);box-shadow:0 12px 40px rgba(255,107,107,.7)}}
.mic-label{font-size:12px;font-weight:700;color:var(--text-muted);text-align:center}
.vocab-strip{width:100%;overflow-x:auto;display:flex;gap:8px;padding:12px 20px;scrollbar-width:none;background:var(--cream)}
.vocab-strip::-webkit-scrollbar{display:none}
.vocab-pill{flex-shrink:0;padding:8px 14px;background:var(--white);border-radius:100px;font-size:13px;font-weight:700;color:var(--purple);box-shadow:var(--shadow-sm);cursor:pointer;transition:background .15s}
.vocab-pill:active{background:var(--purple-pale)}
.timer-bar-wrap{width:100%;height:6px;background:var(--purple-pale);border-radius:0}
.timer-bar{height:100%;border-radius:0;background:var(--yellow);transition:width 1s linear}

/* ── Complete ── */
.stars-row{display:flex;gap:8px;justify-content:center;font-size:36px}
.star-anim{animation:starPop .5s cubic-bezier(.34,1.5,.64,1) forwards;opacity:0}
.star-anim:nth-child(2){animation-delay:.15s}
.star-anim:nth-child(3){animation-delay:.3s}
@keyframes starPop{from{opacity:0;transform:scale(0) rotate(-20deg)}to{opacity:1;transform:scale(1) rotate(0)}}
.result-chips{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.result-chip{background:var(--purple-pale);border-radius:var(--radius-sm);padding:14px;text-align:center}
.result-chip .val{font-family:'Fredoka One',cursive;font-size:32px;color:var(--purple)}
.result-chip .lbl{font-size:11px;font-weight:700;color:var(--text-muted);margin-top:2px}
.vocab-review{display:flex;flex-direction:column;gap:8px}
.vocab-review-item{display:flex;align-items:center;gap:12px;background:var(--white);border-radius:var(--radius-xs);padding:12px 16px;box-shadow:var(--shadow-sm)}
.word-en{font-weight:800;font-size:15px;color:var(--purple)}
.word-ko{font-size:13px;color:var(--text-muted)}

/* ── Admin ── */
.admin-section{margin-bottom:24px}
.admin-section h3{font-size:14px;font-weight:800;color:var(--text-muted);margin-bottom:12px;text-transform:uppercase;letter-spacing:.5px}
.input-field{width:100%;padding:14px 16px;border:2px solid var(--purple-pale);border-radius:var(--radius-xs);font-family:'Nunito',sans-serif;font-size:14px;font-weight:600;color:var(--text);background:var(--white);outline:none;transition:border-color .2s}
.input-field:focus{border-color:var(--purple)}
.session-item{background:var(--white);border-radius:var(--radius-xs);padding:14px 16px;margin-bottom:8px;box-shadow:var(--shadow-sm);display:flex;gap:12px;align-items:center}

/* ── Status badge ── */
.status-badge{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:100px;font-size:12px;font-weight:800}
.status-connected{background:var(--green-light);color:#1B7A40}
.status-connecting{background:var(--yellow);color:#7A5A00}
.status-error{background:var(--coral-light);color:#A83232}
.status-demo{background:var(--purple-pale);color:var(--purple)}

/* ── Toast ── */
#toast{position:fixed;bottom:40px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--text);color:#fff;padding:12px 24px;border-radius:100px;font-size:14px;font-weight:700;z-index:999;transition:transform .3s cubic-bezier(.34,1.2,.64,1);white-space:nowrap;pointer-events:none}
#toast.show{transform:translateX(-50%) translateY(0)}

/* ── Util ── */
.z1{position:relative;z-index:1}
.txt-center{text-align:center}
.mt8{margin-top:8px}.mt12{margin-top:12px}.mt16{margin-top:16px}.mt24{margin-top:24px}
.mb8{margin-bottom:8px}.mb12{margin-bottom:12px}.mb16{margin-bottom:16px}.mb24{margin-bottom:24px}
.flex{display:flex}.items-center{align-items:center}.gap8{gap:8px}.gap12{gap:12px}
.w100{width:100%}.fw800{font-weight:800}.fw600{font-weight:600}
.fs13{font-size:13px}.fs12{font-size:12px}
.col-muted{color:var(--text-muted)}
h1,h2,h3{font-family:'Fredoka One',cursive;letter-spacing:.3px}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-thumb{background:var(--purple-pale);border-radius:2px}
</style>
</head>
<body>

<div class="bg-blobs">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
</div>

<!-- ══════════════════════════════════════
     SCREEN 1 — LOGIN
══════════════════════════════════════ -->
<div id="screen-login" class="screen active">
  <div class="z1 flex items-center txt-center w100"
       style="flex-direction:column;padding:40px 24px 0;min-height:100vh;justify-content:center">

    <!-- Sunny character -->
    <div style="position:relative;display:flex;flex-direction:column;align-items:center;margin-bottom:16px">
