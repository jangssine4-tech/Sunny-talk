<!-- ══════════════════════════════════════
     SCREEN 2 — LESSONS
══════════════════════════════════════ -->
<div id="screen-lessons" class="screen">
  <div class="z1 w100" style="min-height:100vh;padding-bottom:24px">
    <div style="padding:24px 20px 16px;background:var(--white);box-shadow:0 2px 12px rgba(45,27,105,.07)">
      <div class="flex items-center gap8 mb8">
        <button onclick="goTo('screen-login')" class="btn btn-ghost"
                style="width:36px;height:36px;padding:0;border-radius:50%;font-size:16px">←</button>
        <div>
          <p class="fs12 fw600 col-muted">안녕하세요,</p>
          <h2 style="font-size:22px;color:var(--purple)" id="lessons-student-name">학생</h2>
        </div>
        <div style="margin-left:auto">
          <svg width="52" height="56" viewBox="0 0 160 180" style="overflow:visible">
            <g class="sunny-body" style="animation-duration:4s">
              <rect x="54" y="120" width="52" height="36" rx="16" fill="#4A3296"/>
              <ellipse cx="80" cy="122" rx="14" ry="8" fill="#FF6B6B"/>
              <rect x="72" y="108" width="16" height="16" rx="4" fill="#FFD4A3"/>
