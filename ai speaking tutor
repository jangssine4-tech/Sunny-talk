// End Session
// ──────────────────────────────────────
function confirmEndSession() {
  if (confirm('세션을 종료하시겠습니까?')) endSession();
}

function endSession() {
  clearInterval(state.timerInterval);
  disconnectWebRTC();

  if (!state.currentLesson || !state.currentStudent) { goTo('screen-lessons'); return; }

  const elapsed = Math.floor((Date.now() - state.sessionStartTime) / 1000);
  const session = {
    id: Date.now(),
    studentId: state.currentStudent.id,
    studentName: state.currentStudent.name,
    lessonId: state.currentLesson.id,
    lessonTitle: state.currentLesson.title,
    turns: state.sessionTurns,
    seconds: elapsed,
    date: new Date().toLocaleDateString('ko-KR'),
    ts: Date.now(),
  };
  const sessions = LS.getSessions();
  sessions.unshift(session);
  if (sessions.length > 200) sessions.length = 200;
  LS.saveSessions(sessions);
  LS.addCompleted(state.currentStudent.id, state.currentLesson.id);
  state.streak++;

  // Populate complete screen
  document.getElementById('complete-lesson-name').textContent =
    state.currentLesson.icon + ' ' + state.currentLesson.title + ' 완료!';
  document.getElementById('res-turns').textContent = state.sessionTurns;
  document.getElementById('res-words').textContent = state.currentLesson.vocab.length;
  document.getElementById('res-time').textContent = Math.max(1, Math.floor(elapsed / 60)) + '분';
  document.getElementById('res-streak').textContent = '🔥' + state.streak;

  document.getElementById('complete-vocab').innerHTML =
    state.currentLesson.vocab.map(v =>
      `<div class="vocab-review-item">
        <span style="font-size:20px">${state.currentLesson.icon}</span>
        <div><div class="word-en">${v.en}</div><div class="word-ko">${v.ko}</div></div>
        <div style="margin-left:auto;font-size:11px;color:var(--text-muted);font-weight:600;max-width:110px;text-align:right;font-style:italic">${v.ex}</div>
      </div>`
    ).join('');

  const feedbacks = [
    `정말 잘했어요! 오늘 ${state.sessionTurns}번이나 말했어요. 대단해요! 🌟`,
    `와우! ${state.currentLesson.title} 레슨 완료! 내일도 함께 해요 😊`,
    `오늘 배운 ${state.currentLesson.vocab.length}개 단어를 기억해봐요! 💪`,
    '훌륭해요! 영어가 점점 늘고 있어요! Keep it up! ⭐',
  ];
  document.getElementById('complete-feedback').textContent =
    feedbacks[Math.floor(Math.random() * feedbacks.length)];

  goTo('screen-complete');

  // 비동기로 Firestore에 로그 저장
  saveSessionToServer(session);
}

function disconnectWebRTC() {
  if (state.peerConnection) { state.peerConnection.close(); state.peerConnection = null; }
  if (state.dataChannel)    { state.dataChannel.close();    state.dataChannel = null; }
  state.demoMode = false; state.demoIdx = 0; state.connected = false;
}

function repeatLesson() {
  if (state.currentLesson) startLesson(state.currentLesson.id);
}

// ──────────────────────────────────────
// Firestore 로그 저장 (saveSessionLog Function)
// ──────────────────────────────────────
async function saveSessionToServer(session) {
  const settings = LS.getSettings();
  if (!settings.functionsUrl) return;
  // saveSessionLog URL 추측 (getRealtimeToken → saveSessionLog)
  const logUrl = settings.functionsUrl.replace('getRealtimeToken', 'saveSessionLog');
  try {
    await fetch(logUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        studentId: session.studentId,
        studentName: session.studentName,
        lessonId: session.lessonId,
        lessonTitle: session.lessonTitle,
        turns: session.turns,
        seconds: session.seconds,
      }),
    });
  } catch (e) {
    console.warn('세션 로그 서버 저장 실패 (로컬에는 저장됨):', e);
  }
}

// ──────────────────────────────────────
// Admin
// ──────────────────────────────────────
function renderAdminScreen() {
  const s = LS.getSettings();
  if (s.functionsUrl) document.getElementById('functions-url-input').value = s.functionsUrl;
  if (s.appSecret)    document.getElementById('app-secret-input').value = s.appSecret;
  if (s.model)        document.getElementById('model-select').value = s.model;
  if (s.sessionLength) document.getElementById('session-length-select').value = s.sessionLength;
  renderAdminStudents();
  renderSessionLog();
  renderLessonPreview();
}

function saveFunctionsConfig() {
  const url = document.getElementById('functions-url-input').value.trim();
  const sec = document.getElementById('app-secret-input').value.trim();
  if (!url) { toast('Functions URL을 입력해주세요'); return; }
  LS.saveSettings({ functionsUrl: url, appSecret: sec });
  document.getElementById('url-saved-badge').textContent = '✅ 저장됨';
  toast('✅ 서버 설정 저장 완료');
  checkFunctionsStatus();
}

async function testFunctionsConnection() {
  const url = document.getElementById('functions-url-input').value.trim();
  const sec = document.getElementById('app-secret-input').value.trim();
  const el = document.getElementById('test-result');
  if (!url) { toast('URL을 먼저 입력하세요'); return; }
  el.textContent = '⏳ 테스트 중...'; el.style.color = 'var(--text-muted)';
  try {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-app-secret': sec },
      body: JSON.stringify({ model: 'gpt-4o-mini-realtime-preview-2024-12-17', instructions: 'test' }),
    });
    if (res.ok) {
      el.textContent = '✅ 연결 성공! Functions가 정상 동작합니다.';
      el.style.color = 'var(--green)';
    } else {
      const err = await res.json().catch(() => ({}));
      el.textContent = '❌ 오류 ' + res.status + ': ' + (err.error || '');
      el.style.color = 'var(--coral)';
    }
  } catch (e) {
    el.textContent = '❌ 네트워크 오류: ' + e.message;
    el.style.color = 'var(--coral)';
  }
}

function saveModelSettings() {
  LS.saveSettings({
    model: document.getElementById('model-select').value,
    sessionLength: parseInt(document.getElementById('session-length-select').value),
  });
  toast('✅ 모델 설정 저장 완료');
}

function addStudent() {
  const name = document.getElementById('new-student-name').value.trim();
  const pin  = document.getElementById('new-student-pin').value.trim();
  if (!name) { toast('이름을 입력해주세요'); return; }
  if (!/^\d{4}$/.test(pin)) { toast('PIN은 숫자 4자리입니다'); return; }
  const students = LS.getStudents();
  students.push({ id: 'S' + Date.now(), name, pin });
  LS.saveStudents(students);
  document.getElementById('new-student-name').value = '';
  document.getElementById('new-student-pin').value = '';
  renderAdminStudents(); renderStudentList();
  toast('✅ ' + name + ' 추가 완료');
}

function deleteStudent(id) {
  if (!confirm('삭제하시겠습니까?')) return;
  LS.saveStudents(LS.getStudents().filter(s => s.id !== id));
  renderAdminStudents(); renderStudentList();
  toast('삭제 완료');
}

function renderAdminStudents() {
  const students = LS.getStudents();
  const el = document.getElementById('student-admin-list');
  if (!students.length) { el.innerHTML = '<p class="fs13 col-muted fw600">등록된 학생이 없습니다</p>'; return; }
  el.innerHTML = students.map(s => {
    const done = LS.getCompleted(s.id);
    return `<div class="session-item">
      <span style="font-size:20px">👤</span>
      <div style="flex:1">
        <div class="fw800 fs13">${s.name}</div>
        <div class="fs12 col-muted fw600">PIN: ${s.pin} · 완료 레슨: ${done.length}개</div>
      </div>
      <button onclick="deleteStudent('${s.id}')" class="btn btn-ghost"
              style="padding:6px 12px;font-size:12px;color:var(--coral)">삭제</button>
    </div>`;
  }).join('');
}

function renderSessionLog() {
  const sessions = LS.getSessions().slice(0, 10);
  const el = document.getElementById('session-log');
  if (!sessions.length) { el.innerHTML = '<p class="fs13 col-muted fw600">세션 기록이 없습니다</p>'; return; }
  el.innerHTML = sessions.map(s =>
    `<div class="session-item">
      <span style="font-size:18px">💬</span>
      <div style="flex:1">
        <div class="fw800 fs13">${s.studentName} · ${s.lessonTitle}</div>
        <div class="fs12 col-muted fw600">${s.date} · ${s.turns}회 대화 · ${Math.floor(s.seconds/60)}분</div>
      </div>
    </div>`
  ).join('');
}

function renderLessonPreview() {
  document.getElementById('lesson-preview-list').innerHTML = LESSONS.map(l =>
    `<div class="session-item">
      <span style="font-size:20px">${l.icon}</span>
      <div style="flex:1">
        <div class="fw800 fs13">Day ${l.day}: ${l.title}</div>
        <div class="fs12 col-muted fw600">${l.titleKo} · 단어 ${l.vocab.length}개 · ${l.level}</div>
      </div>
    </div>`
  ).join('');
}

// ──────────────────────────────────────
// 연결 상태 확인
// ──────────────────────────────────────
async function checkFunctionsStatus() {
  const settings = LS.getSettings();
  const badge = document.getElementById('conn-status');
  if (!settings.functionsUrl) {
    badge.className = 'status-badge status-demo mt12';
    badge.textContent = '⚠️ Functions URL 미설정 (데모 모드)';
    return;
  }
  badge.className = 'status-badge status-connecting mt12';
  badge.textContent = '⏳ 서버 확인 중...';
  try {
    const res = await fetch(settings.functionsUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-app-secret': settings.appSecret || '' },
      body: JSON.stringify({ model: 'gpt-4o-mini-realtime-preview-2024-12-17', instructions: 'ping' }),
    });
    if (res.ok) {
      badge.className = 'status-badge status-connected mt12';
      badge.textContent = '🟢 서버 연결됨';
    } else {
      badge.className = 'status-badge status-error mt12';
      badge.textContent = '❌ 서버 오류 ' + res.status;
    }
  } catch {
    badge.className = 'status-badge status-error mt12';
    badge.textContent = '❌ 서버 연결 불가';
  }
}

// ──────────────────────────────────────
// Init
// ──────────────────────────────────────
function init() {
  // 데모 학생 추가 (처음 실행 시)
  if (!LS.getStudents().length) {
    LS.saveStudents([
      { id: 'S_demo1', name: '민서', pin: '1234' },
      { id: 'S_demo2', name: '준호', pin: '1234' },
      { id: 'S_demo3', name: '지유', pin: '1234' },
    ]);
  }
  renderStudentList();
  checkFunctionsStatus();
}

init();
</script>
