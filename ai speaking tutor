function goTo(id) {
  document.querySelectorAll('.screen.active').forEach(s => {
    if (s.id !== id) {
      s.classList.add('exit');
      setTimeout(() => s.classList.remove('active', 'exit'), 300);
    }
  });
  setTimeout(() => document.getElementById(id).classList.add('active'), 100);
}
