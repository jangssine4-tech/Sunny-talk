const DEMO_SCRIPT = [
  "Hello! I'm Sunny! What's your name? 😊",
  "Nice to meet you! How are you today?",
  "That's great! Let's practice English together! 🌟",
  'Can you say: "Nice to meet you!"',
  "Excellent! 잘했어요! You're doing so well!",
  'Now try: "I am happy today!"',
  "Perfect! 정말 잘했어요! You\'re an amazing English speaker! ⭐",
];

function startDemoMode() {
  state.demoMode = true;
  state.demoIdx = 0;
  document.getElementById('mic-btn').disabled = false;
  document.getElementById('mic-label').textContent = '🔵 데모 모드 — 마이크 버튼을 눌러보세요';
  setSessionStatus('demo');
  setTimeout(() => addAiBubble(DEMO_SCRIPT[state.demoIdx++]), 1000);
}

// ──────────────────────────────────────
// Mic
// ──────────────────────────────────────
function toggleMic() {
  if (state.demoMode) {
    setListening(!state.isListening);
    if (!state.isListening) {
      setTimeout(() => {
        setListening(false);
        addUserBubble('Hello! Nice to meet you! I am happy! 😊');
        setTimeout(() => {
          if (state.demoIdx < DEMO_SCRIPT.length) addAiBubble(DEMO_SCRIPT[state.demoIdx++]);
        }, 600);
      }, 1500);
    }
    return;
  }
  if (!state.isListening) {
    setListening(true);
  } else {
    setListening(false);
    sendEvent({ type: 'input_audio_buffer.commit' });
    sendEvent({ type: 'response.create' });
  }
}

function setListening(val) {
  state.isListening = val;
  const btn = document.getElementById('mic-btn');
  btn.classList.toggle('listening', val);
  btn.textContent = val ? '⏹' : '🎤';
  document.getElementById('mic-label').textContent =
    val ? '🎤 말하고 있어요... 멈추면 자동 전송됩니다!' : '마이크 버튼을 눌러 말해보세요!';
}

function setSunnyTalking(val) {
  state.isSpeaking = val;
  document.getElementById('sunny-convo').classList.toggle('talking', val);
}

// ──────────────────────────────────────
// Chat bubbles
// ──────────────────────────────────────
let _curBubble = null, _curText = '';

function addAiBubble(text) {
  hideSunnyCenter();
  const area = document.getElementById('chat-area');
  _curBubble = document.createElement('div');
  _curBubble.className = 'chat-bubble bubble-ai';
  _curBubble.textContent = text;
  area.appendChild(_curBubble);
  area.scrollTop = area.scrollHeight;
  _curText = text;
  setSunnyTalking(true);
  setTimeout(() => setSunnyTalking(false), text.length * 55 + 400);
}

function updateLastAiBubble(delta) {
  if (!_curBubble) {
    hideSunnyCenter();
    const area = document.getElementById('chat-area');
    _curBubble = document.createElement('div');
    _curBubble.className = 'chat-bubble bubble-ai';
    _curBubble.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
    area.appendChild(_curBubble);
  }
  _curText += delta;
  _curBubble.textContent = _curText;
  document.getElementById('chat-area').scrollTop = 9999;
}

function finalizeAiBubble(text) {
  if (_curBubble) _curBubble.textContent = text || _curText;
  _curBubble = null; _curText = '';
}

function addUserBubble(text) {
  hideSunnyCenter();
  const area = document.getElementById('chat-area');
  const b = document.createElement('div');
  b.className = 'chat-bubble bubble-user';
  b.textContent = text;
  area.appendChild(b);
  area.scrollTop = 9999;
}

function hideSunnyCenter() {
  const c = document.getElementById('sunny-center');
  if (c) c.style.display = 'none';
}

function showHint() {
  const l = state.currentLesson; if (!l) return;
  const e = l.expressions[Math.floor(Math.random() * l.expressions.length)];
  const area = document.getElementById('chat-area');
  const b = document.createElement('div');
  b.className = 'chat-bubble bubble-hint';
  b.textContent = '💡 힌트: "' + e.phrase + '" — ' + e.ko;
  area.appendChild(b);
  area.scrollTop = 9999;
}

function skipTurn() {
  if (state.demoMode) {
    if (state.demoIdx < DEMO_SCRIPT.length) addAiBubble(DEMO_SCRIPT[state.demoIdx++]);
    return;
  }
  sendEvent({ type: 'response.create', response: { modalities: ['audio', 'text'] } });
}

function vocabTap(word) {
  toast('💡 "' + word + '" 를 대화에서 사용해보세요!');
}

