  demoMode: false,
  demoIdx: 0,
  connected: false,
};

// ──────────────────────────────────────
// 레슨 데이터
// ──────────────────────────────────────
const LESSONS = [
  {
    id:'L01', day:1, icon:'👋', title:'Greetings & Introductions', titleKo:'인사와 자기소개', level:'beginner',
    vocab:[
      {en:'hello',       ko:'안녕하세요',   ex:'Hello! My name is Sunny.'},
      {en:'nice',        ko:'좋은',         ex:'Nice to meet you!'},
      {en:'my name',     ko:'내 이름',      ex:'My name is Minseo.'},
      {en:'how are you', ko:'잘 지내나요?', ex:'How are you today?'},
      {en:'fine',        ko:'괜찮아요',     ex:"I'm fine, thank you!"},
    ],
    expressions:[
      {phrase:'Nice to meet you!',  ko:'만나서 반가워요!'},
      {phrase:'How are you?',       ko:'잘 지내요?'},
      {phrase:"I'm doing great!",   ko:'저는 정말 잘 지내요!'},
    ],
    grammar:{point:'I am + 형용사', example:'I am happy / I am fine / I am excited!'},
    systemPrompt:`You are Sunny, an adorable and encouraging English tutor for Korean elementary students.
Today's lesson is "Greetings & Introductions".
Key vocabulary: hello, nice, my name, how are you, fine.
Key expressions: "Nice to meet you!", "How are you?", "I'm doing great!"
Grammar focus: I am + adjective

Rules:
- Keep ALL responses to 1-2 short sentences max.
- Start by introducing yourself warmly and ask the student's name.
- If student makes a grammar mistake, continue conversation and naturally model the correct form. Never explicitly correct.
- If student seems stuck, give a hint like: You can say: "Nice to meet you!"
- Mix in occasional Korean encouragement: 잘했어요! or Good job!
- After every 2-3 exchanges, introduce a new vocab word naturally.
- Speak slowly and clearly. Elementary level only.`,
  },
  {
    id:'L02', day:2, icon:'👨‍👩‍👧', title:'My Family', titleKo:'우리 가족', level:'beginner',
    vocab:[
      {en:'mother',  ko:'어머니',    ex:'My mother is kind.'},
      {en:'father',  ko:'아버지',    ex:'My father is tall.'},
      {en:'brother', ko:'남자 형제', ex:'I have one brother.'},
      {en:'sister',  ko:'여자 형제', ex:'My sister is funny.'},
      {en:'family',  ko:'가족',      ex:'I love my family!'},
    ],
    expressions:[
      {phrase:'I have a brother.',      ko:'저는 남자 형제가 있어요.'},
      {phrase:'My mother is very kind.',ko:'우리 엄마는 정말 친절해요.'},
      {phrase:'We are a happy family.', ko:'우리는 행복한 가족이에요.'},
    ],
    grammar:{point:'have/has 소유 표현', example:'I have a sister. / She has a brother.'},
    systemPrompt:`You are Sunny, a fun English tutor for Korean kids.
Today's lesson: "My Family".
Vocab: mother, father, brother, sister, family.
Expressions: "I have a brother.", "My mother is very kind.", "We are a happy family."
Grammar: have/has

Rules: Keep responses 1-2 sentences. Ask about their own family. Warm and encouraging. Model correct grammar naturally.`,
  },
  {
    id:'L03', day:3, icon:'🍕', title:'Food I Love', titleKo:'내가 좋아하는 음식', level:'beginner',
    vocab:[
      {en:'favorite',   ko:'가장 좋아하는', ex:'My favorite food is pizza.'},
      {en:'delicious',  ko:'맛있는',        ex:'This is so delicious!'},
      {en:'hungry',     ko:'배고픈',        ex:'I am hungry.'},
