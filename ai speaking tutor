function renderStudentList() {
  const students = LS.getStudents();
  const el = document.getElementById('student-list');
  if (!students.length) {
    el.innerHTML = '<p style="font-size:13px;color:var(--text-muted);font-weight:700">관리자에서 학생을 추가해주세요</p>';
    return;
  }
  el.innerHTML = students.map(s =>
    `<button onclick="selectStudent('${s.id}')" class="btn btn-ghost" style="font-size:15px;padding:10px 20px">${s.name}</button>`
  ).join('');
}

function selectStudent(id) {
  state.currentStudent = LS.getStudents().find(s => s.id === id);
  if (!state.currentStudent) return;
  document.getElementById('pin-student-name').textContent = `${state.currentStudent.name}의 PIN을 입력하세요`;
  document.getElementById('student-select-area').style.display = 'none';
  document.getElementById('pin-area').style.display = 'flex';
  state.pinInput = '';
  updateDots();
}

function clearStudentSelect() {
  document.getElementById('student-select-area').style.display = '';
  document.getElementById('pin-area').style.display = 'none';
  state.pinInput = '';
}

function pinInput(d) {
  if (state.pinInput.length >= 4) return;
  state.pinInput += d; updateDots();
  if (state.pinInput.length === 4) setTimeout(checkPin, 150);
}
function pinDelete() { state.pinInput = state.pinInput.slice(0, -1); updateDots(); }
function updateDots() {
  for (let i = 0; i < 4; i++)
    document.getElementById('dot' + i).classList.toggle('filled', i < state.pinInput.length);
}
function checkPin() {
  if (state.pinInput === state.currentStudent.pin) {
    state.streak = LS.getSessions().filter(s => s.studentId === state.currentStudent.id).length;
    goToLessons();
  } else {
    toast('PIN이 맞지 않아요 😅');
    state.pinInput = ''; updateDots();
  }
}

