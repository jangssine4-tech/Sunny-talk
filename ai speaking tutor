const LS = {
  get: (k) => { try { return JSON.parse(localStorage.getItem(k)); } catch { return null; } },
  set: (k, v) => localStorage.setItem(k, JSON.stringify(v)),
  getStudents: () => LS.get('st_students') || [],
  saveStudents: (a) => LS.set('st_students', a),
  getSessions: () => LS.get('st_sessions') || [],
  saveSessions: (a) => LS.set('st_sessions', a),
  getSettings: () => LS.get('st_settings') || {},
  saveSettings: (o) => LS.set('st_settings', { ...LS.getSettings(), ...o }),
  getCompleted: (sid) => LS.get('st_done_' + sid) || [],
  addCompleted: (sid, lid) => {
    const a = LS.getCompleted(sid);
    if (!a.includes(lid)) { a.push(lid); LS.set('st_done_' + sid, a); }
  },
};

